@media (max-width: 400px) {
  .chat-panel {
    width: calc(100vw - 24px);
    right: 12px;
    bottom: 84px;
  }
  .chat-fab {
    right: 16px;
    bottom: 16px;
  }
}

/* ─── Chat header actions ────────────────────────────────────────────────── */

