@tailwind base;
@tailwind components;
@tailwind utilities;

/* ─── Design tokens ──────────────────────────────────────────────────────── */
:root {
  --bg: #0d0f10;
  --surface: #141618;
  --surface-2: #1c1f21;
  --border: rgba(255, 255, 255, 0.07);
  --green: #3ddc84;
  --green-dim: rgba(61, 220, 132, 0.12);
  --green-mid: rgba(61, 220, 132, 0.25);
  --text: #e8e9ea;
  --text-muted: #7a7f84;
